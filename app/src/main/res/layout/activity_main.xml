<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <!-- Camera stream fills the screen -->
    <com.smallcar.controller.view.CameraStreamView
        android:id="@+id/cameraView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- HUD overlay panel at bottom -->
    <FrameLayout
        android:id="@+id/hudPanel"
        android:layout_width="0dp"
        android:layout_height="180dp"
        android:background="@color/hud_panel"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Joystick on the left -->
        <com.smallcar.controller.view.JoystickView
            android:id="@+id/joystick"
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:layout_gravity="start|center_vertical"
            android:layout_marginStart="20dp" />

        <!-- Speed label + seekbar in center -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:text="@string/speed"
                android:textColor="@color/text_gold"
                android:textSize="11sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp" />

            <SeekBar
                android:id="@+id/speedBar"
                android:layout_width="160dp"
                android:layout_height="wrap_content"
                android:max="100"
                android:progress="60"
                android:progressTint="@color/accent_blue"
                android:thumbTint="@color/accent_gold" />

        </LinearLayout>

        <!-- Function buttons on the right -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end|center_vertical"
            android:layout_marginEnd="20dp"
            android:orientation="vertical"
            android:spacing="8dp">

            <Button
                android:id="@+id/btnHorn"
                style="@style/HudButton"
                android:layout_width="80dp"
                android:layout_height="44dp"
                android:text="@string/horn"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/btnLight"
                style="@style/HudButton"
                android:layout_width="80dp"
                android:layout_height="44dp"
                android:text="@string/light"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/btnSettings"
                style="@style/HudButton"
                android:layout_width="80dp"
                android:layout_height="44dp"
                android:text="@string/settings" />

        </LinearLayout>

    </FrameLayout>

    <!-- Top-right status bar -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <View
            android:id="@+id/statusDot"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="@color/status_disconnected"
            android:layout_marginEnd="6dp" />

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/status_disconnected"
            android:textColor="@color/text_primary"
            android:textSize="12sp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
