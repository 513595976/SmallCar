<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <!-- Camera stream fills the screen -->
    <com.smallcar.controller.view.CameraStreamView
        android:id="@+id/cameraView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Left top control panel -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginStart="20dp"
        android:layout_marginTop="20dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Mode toggle button -->
        <ImageButton
            android:id="@+id/btnModeToggle"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_run"
            android:background="@drawable/btn_mode"
            android:scaleType="centerInside"
            android:clickable="true"
            android:layout_marginEnd="8dp" />

        <!-- Mode status text -->
        <TextView
            android:id="@+id/tvModeStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="运行模式"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:layout_marginStart="10dp"
            android:layout_gravity="center_vertical" />

    </LinearLayout>

    <!-- Left side behavior panel (mid-upper) -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginStart="20dp"
        android:layout_marginTop="100dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnBehaviorToggle"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_wander"
            android:background="@drawable/btn_mode"
            android:scaleType="centerInside"
            android:clickable="true"
            android:layout_marginEnd="8dp" />

        <!-- Behavior status text -->
        <TextView
            android:id="@+id/tvBehaviorStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="游走"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:layout_gravity="center_vertical" />

    </LinearLayout>

    <!-- Intensity and XY display at bottom center -->
    <LinearLayout
        android:id="@+id/metricPanel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:visibility="gone"
        android:layout_marginBottom="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:text="强度:"
            android:textColor="@android:color/white"
            android:textSize="12sp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="6dp" />

        <TextView
            android:id="@+id/tvIntensity"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0.00"
            android:textColor="@color/accent_gold"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginEnd="16dp" />

        <TextView
            android:text="X:"
            android:textColor="@android:color/white"
            android:textSize="12sp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="6dp" />

        <TextView
            android:id="@+id/tvX"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0.00"
            android:textColor="@color/accent_gold"
            android:textSize="12sp"
            android:layout_marginEnd="16dp" />

        <TextView
            android:text="Y:"
            android:textColor="@android:color/white"
            android:textSize="12sp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="6dp" />

        <TextView
            android:id="@+id/tvY"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0.00"
            android:textColor="@color/accent_gold"
            android:textSize="12sp" />

    </LinearLayout>

    <!-- HUD overlay panel at bottom (transparent background) -->
    <FrameLayout
        android:id="@+id/hudPanel"
        android:layout_width="0dp"
        android:layout_height="220dp"
        android:background="#00000000"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Joystick on the left -->
        <com.smallcar.controller.view.JoystickView
            android:id="@+id/joystick"
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:layout_gravity="start|center_vertical"
            android:layout_marginStart="20dp" />

        <!-- Servo and fire controls on the right -->
        <FrameLayout
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_gravity="end|bottom"
            android:layout_marginEnd="20dp"
            android:layout_marginBottom="10dp">

            <ImageButton
                android:id="@+id/btnFire"
                style="@style/HudButton"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_gravity="top|center_horizontal"
                android:src="@drawable/ic_fire"
                android:contentDescription="@string/fire"
                android:scaleType="fitCenter" />

            <ImageButton
                android:id="@+id/btnServoLeft"
                style="@style/HudButton"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_gravity="bottom|start"
                android:src="@drawable/ic_arrow_left"
                android:contentDescription="@string/servo_left"
                android:layout_marginBottom="5dp"
                android:scaleType="fitCenter" />

            <ImageButton
                android:id="@+id/btnServoRight"
                style="@style/HudButton"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_gravity="bottom|end"
                android:src="@drawable/ic_arrow_right"
                android:contentDescription="@string/servo_right"
                android:layout_marginBottom="5dp"
                android:scaleType="fitCenter" />

        </FrameLayout>

    </FrameLayout>

    <!-- Top-right status bar -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <View
            android:id="@+id/statusDot"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="@color/status_disconnected"
            android:layout_marginEnd="6dp" />

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/status_disconnected"
            android:textColor="@color/text_primary"
            android:textSize="12sp" />

        <ImageButton
            android:id="@+id/btnSettings"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/gear_icon"
            android:background="@drawable/btn_hud"
            android:scaleType="centerInside"
            android:layout_marginStart="10dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>

